# ============================================================
#  AI Talent Finder — environment template
#  Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ----- PostgreSQL -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_talent_finder
# Use service name "db" inside docker-compose, "localhost" outside.
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_talent_finder

# ----- Security / JWT -----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-cryptographically-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- LLM (Anthropic Claude) -----
# Get a key at https://console.anthropic.com/
LLM_API_KEY=sk-ant-your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ----- NLP -----
# Install with: python -m spacy download fr_core_news_md
SPACY_MODEL=fr_core_news_md

# ----- Application -----
ENVIRONMENT=development
DEBUG=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Comma-separated list, no trailing slash.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ----- Uploads -----
CV_UPLOAD_DIR=./uploads/cvs
MAX_UPLOAD_SIZE_MB=10

# ----- Rate limiting -----
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_DEFAULT=100/minute

# ----- Frontend (Next.js public env) -----
NEXT_PUBLIC_API_URL=http://localhost:8000
